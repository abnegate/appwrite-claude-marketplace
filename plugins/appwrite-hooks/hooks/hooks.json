{
  "description": "Commit-time guards: conflict markers, TEMP/HACK/FIXME markers, conventional commits with --no-verify/--amend blocking, regression tests, format-and-lint. Push-time guards: force-push to protected branches. Edit-time guards: secret-bearing files. Shell guards: rm -rf on system paths.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "php ${CLAUDE_PLUGIN_ROOT}/hooks/destructive_guard.php"
          },
          {
            "type": "command",
            "command": "php ${CLAUDE_PLUGIN_ROOT}/hooks/force_push_guard.php"
          },
          {
            "type": "command",
            "command": "php ${CLAUDE_PLUGIN_ROOT}/hooks/staged_diff_scan.php"
          },
          {
            "type": "command",
            "command": "php ${CLAUDE_PLUGIN_ROOT}/hooks/conventional_commit.php"
          },
          {
            "type": "command",
            "command": "php ${CLAUDE_PLUGIN_ROOT}/hooks/regression_test.php"
          },
          {
            "type": "command",
            "command": "php ${CLAUDE_PLUGIN_ROOT}/hooks/format_lint.php"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "php ${CLAUDE_PLUGIN_ROOT}/hooks/secrets_guard.php"
          }
        ]
      }
    ]
  }
}
